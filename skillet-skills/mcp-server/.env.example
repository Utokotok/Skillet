# ============================================
# Skillet GitHub MCP Server - Environment Variables
# ============================================
#
# IMPORTANT: All variables are REQUIRED. The server will not start if any are missing.
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# Then edit .env with your configuration.
#
# ============================================

# --------------------------------------------
# GitHub Authentication
# --------------------------------------------
#
# Your GitHub Personal Access Token (PAT)
# 
# How to get one:
# 1. Go to: https://github.com/settings/tokens
# 2. Click "Generate new token (classic)"
# 3. Select scope: "repo" (Full control of private repositories)
# 4. Copy the token (starts with ghp_)
#
# SECURITY: Never commit this token to git!
#
# Format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=your_github_token_here

# --------------------------------------------
# GitHub Configuration
# --------------------------------------------

# Your GitHub username (the owner of the repositories)
GITHUB_OWNER=your_github_username

# Name of the policies repository (read-only access)
POLICIES_REPO=skillet-policies

# Name of the skills repository (read-write access)
SKILLS_REPO=skillet-skills

# Default branch to use for operations
DEFAULT_BRANCH=main

# --------------------------------------------
# File Paths
# --------------------------------------------

# Path to the skill metadata file (relative to skills repo root)
METADATA_PATH=metadata/skill-index.json

# Absolute path to the built MCP server file
# This is used by Bob IDE to locate the server
# 
# Windows example: C:/Users/YourUsername/path/to/skillet-skills/mcp-server/build/index.js
# Linux/Mac example: /home/username/path/to/skillet-skills/mcp-server/build/index.js
#
# IMPORTANT: Use forward slashes (/) even on Windows
MCP_SERVER_BUILD_PATH=/absolute/path/to/skillet-skills/mcp-server/build/index.js