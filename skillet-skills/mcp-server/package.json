{
  "name": "skillet-github-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for accessing Skillet GitHub repositories",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "validate": "node validate-env.js",
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "github",
    "skillet"
  ],
  "author": "IvanDaHackerz",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^16.4.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
